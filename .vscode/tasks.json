{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "start-vite",
      "type": "shell",
      "command": "pnpm dev",
      "isBackground": true,
      "problemMatcher": {
        "pattern": [{ "regexp": ".", "file": 1, "location": 2, "message": 3 }],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "ready in"
        }
      },
      "presentation": { "reveal": "never", "panel": "new" }
    },
    {
      "label": "build-rust-debug",
      "type": "shell",
      "command": "powershell -File \"${workspaceFolder}/scripts/build.ps1\"",
      "group": "build",
      "presentation": { "reveal": "silent", "panel": "new" }
    },
    {
      "label": "pre-tauri-debug",
      "dependsOrder": "parallel",
      "dependsOn": ["start-vite", "build-rust-debug"],
      "problemMatcher": []
    },
    {
      "label": "clear-provider-wire-log",
      "type": "shell",
      "command": "Remove-Item \"$env:APPDATA\\com.squirecli.app\\provider-wire.log\" -Force -ErrorAction SilentlyContinue; Write-Output 'provider-wire.log deleted'",
      "problemMatcher": []
    },
    {
      "label": "run-app",
      "type": "shell",
      "command": "powershell -File \"${workspaceFolder}/scripts/run.ps1\"",
      "group": "none",
      "presentation": { "reveal": "silent", "panel": "new" }
    },
    {
      "label": "test-rust",
      "type": "shell",
      "command": "powershell -File \"${workspaceFolder}/scripts/test.ps1\"",
      "group": "test",
      "presentation": { "reveal": "silent", "panel": "new" }
    },
    {
      "label": "test-rust-all",
      "type": "shell",
      "command": "powershell -File \"${workspaceFolder}/scripts/test-all.ps1\"",
      "group": "test",
      "presentation": { "reveal": "silent", "panel": "new" }
    },
    {
      "label": "test-frontend",
      "type": "shell",
      "command": "powershell -File \"${workspaceFolder}/scripts/frontend-test.ps1\"",
      "group": "test",
      "presentation": { "reveal": "silent", "panel": "new" }
    }
  ]
}
